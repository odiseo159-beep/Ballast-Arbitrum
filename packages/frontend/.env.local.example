# Backend HTTP URL (where packages/backend is serving from)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Public RPC for Robinhood Chain Testnet.
# NOTE: this URL is bundled into the browser. For the hackathon we use a
# testnet-only Alchemy key — rotate it after the buildathon.
NEXT_PUBLIC_RPC_URL=https://robinhood-testnet.g.alchemy.com/v2/REPLACE_ME
