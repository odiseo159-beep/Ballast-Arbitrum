# ─────────────────────────────────────────────────────────────
# Ballast — environment variables template
# COPY this file to .env (which is gitignored) and fill in real values.
# NEVER paste real secrets into this template, and never commit a .env.
# ─────────────────────────────────────────────────────────────

# Robinhood Chain Testnet
# Get from https://www.alchemy.com → create app on "Robinhood Chain Testnet"
ALCHEMY_RPC_URL=https://robinhood-testnet.g.alchemy.com/v2/REPLACE_ME
CHAIN_ID=46630
EXPLORER_URL=https://explorer.testnet.chain.robinhood.com

# Deployer / oracle wallet
# IMPORTANT: use a FRESH wallet dedicated to the hackathon, never one with real funds.
# Fund it via the faucet: https://faucet.testnet.chain.robinhood.com/
DEPLOYER_PRIVATE_KEY=0xREPLACE_ME

# Anthropic API key for the agent backend
# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# AllocationDesk deployed address — filled in after Phase 1 deploy
ALLOCATION_DESK_ADDRESS=

# Off-chain finance data API (Phase 2)
# e.g. Alpha Vantage / Twelve Data / Finnhub — pick one in Phase 2
FINANCE_API_KEY=

# FX rate API (Phase 2) — e.g. exchangerate.host (free, no key) or openexchangerates
FX_API_KEY=
